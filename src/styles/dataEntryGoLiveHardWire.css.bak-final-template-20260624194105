/* Data Entry Go-Live hard-wire mode.
   This intentionally overrides the current component when REGISTER NOW is clicked. */

html.be-dataentry-golive-active,
html.be-dataentry-golive-active body {
  overflow: hidden !important;
}

html.be-dataentry-golive-active aside,
html.be-dataentry-golive-active [data-sidebar],
html.be-dataentry-golive-active nav[aria-label*="Sidebar"],
html.be-dataentry-golive-active .sidebar,
html.be-dataentry-golive-active [class*="Sidebar"],
html.be-dataentry-golive-active [class*="sidebar"] {
  display: none !important;
  width: 0 !important;
  min-width: 0 !important;
  max-width: 0 !important;
  opacity: 0 !important;
  pointer-events: none !important;
}

html.be-dataentry-golive-active main,
html.be-dataentry-golive-active [role="main"] {
  width: 100vw !important;
  max-width: 100vw !important;
  margin-left: 0 !important;
  padding-left: 12px !important;
  padding-right: 12px !important;
}

#be-dataentry-golive-mount {
  display: none;
}

html.be-dataentry-golive-active #be-dataentry-golive-mount {
  display: block !important;
  position: fixed !important;
  inset: 0 !important;
  z-index: 2147483000 !important;
  overflow: auto !important;
  background: #061524 !important;
  color: #eef8ff !important;
  padding: 14px !important;
  box-sizing: border-box !important;
  font-family: Inter, system-ui, Arial, sans-serif !important;
}

.be-de-shell {
  min-width: 1500px;
}

.be-de-toolbar {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 14px 16px;
  border: 1px solid #1a3a5c;
  border-radius: 18px;
  background: #0b2236;
  box-shadow: 0 10px 30px rgba(0,0,0,.35);
}

.be-de-title {
  color: #f6b84b;
  font-weight: 1000;
  letter-spacing: .18em;
  text-transform: uppercase;
  font-size: 14px;
}

.be-de-subtitle {
  margin-top: 6px;
  color: #9fc3dc;
  font-size: 13px;
}

.be-de-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.be-de-actions button {
  border: 1px solid #2b5b85;
  border-radius: 12px;
  background: #102b44;
  color: #eef8ff;
  padding: 10px 14px;
  font-weight: 900;
  cursor: pointer;
}

.be-de-actions button.primary {
  background: #f6b84b;
  color: #061524;
  border-color: #f6b84b;
}

.be-de-actions button.green {
  background: #10c784;
  color: #061524;
  border-color: #10c784;
}

.be-de-proof-strip {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding: 14px 0;
  margin: 12px 0;
}

.be-de-proof-card {
  width: 180px;
  min-width: 180px;
  border: 1px solid #1a3a5c;
  border-radius: 14px;
  background: #071a2b;
  overflow: hidden;
}

.be-de-proof-card img {
  display: block;
  width: 100%;
  height: 112px;
  object-fit: cover;
  background: #0b2236;
}

.be-de-proof-meta {
  padding: 9px;
  font-size: 11px;
  color: #9fc3dc;
}

.be-de-proof-status {
  color: #f6b84b;
  font-weight: 900;
}

.be-de-table-wrap {
  border: 1px solid #1a3a5c;
  border-radius: 18px;
  overflow: auto;
  background: #071a2b;
  min-height: calc(100vh - 250px);
}

.be-de-table {
  width: 100%;
  min-width: 2200px;
  border-collapse: collapse;
}

.be-de-table th {
  position: sticky;
  top: 0;
  background: #f6b84b;
  color: #061524;
  padding: 10px;
  font-size: 12px;
  text-align: left;
  z-index: 2;
}

.be-de-table td {
  border-top: 1px solid #102b44;
  padding: 7px;
}

.be-de-table input,
.be-de-table textarea,
.be-de-table select {
  width: 100%;
  min-width: 140px;
  box-sizing: border-box;
  border: 1px solid #1a3a5c;
  border-radius: 8px;
  background: #061524;
  color: #eef8ff;
  padding: 8px 10px;
  font-size: 13px;
}

.be-de-table textarea {
  min-height: 44px;
}

.be-de-pending {
  color: #f6b84b;
  font-size: 12px;
  font-weight: 900;
  white-space: nowrap;
}

.be-de-hidden-page main > *:not(#be-dataentry-golive-mount),
.be-de-hidden-page [role="main"] > *:not(#be-dataentry-golive-mount) {
  display: none !important;
}
