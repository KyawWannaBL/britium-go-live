];

function sizeConfig(size: PaperSize) {
  switch (size) {
    case "A4":
      return { page: "A4", labelW: "105mm", labelH: "148.5mm", perPage: 4, previewClass: "a4" };
    case "A5":
      return { page: "A5", labelW: "148mm", labelH: "105mm", perPage: 2, previewClass: "a5" };
    case "4x3":
      return { page: "4in 3in", labelW: "4in", labelH: "3in", perPage: 1, previewClass: "four-three" };
    case "2x3":
      return { page: "2in 3in", labelW: "2in", labelH: "3in", perPage: 1, previewClass: "two-three" };
    case "4x6":
    default:
      return { page: "4in 6in", labelW: "4in", labelH: "6in", perPage: 1, previewClass: "four-six" };
  }
}

function readFirst(row: any, names: string[], fallback: any = "") {
  for (const name of names) {
    if (row?.[name] !== undefined && row?.[name] !== null && String(row[name]).trim() !== "") return row[name];
  }
  return fallback;
}

function money(n?: number | null) {
  const value = Number(n || 0);
  if (!value) return "000,000,000";
  return value.toLocaleString("en-US").padStart(11, "0");
}

function cleanText(v: any, fallback = "") {
  const text = String(v ?? "").trim();
  return text || fallback;
}

function normalizeWaybill(row: any, index: number): WaybillRow {
  const tracking = String(
    readFirst(row, [
      "waybill_no",
      "tracking_no",
      "deliveryway_id",
      "delivery_way_id",
      "way_id",
      "pickup_id",
      "pickup_request_id",
      "id",
    ], `YGN${String(index + 119874).padStart(6, "0")}YGN`)
  );

  const township = readFirst(row, ["delivery_township", "township", "recipient_township", "town"], "");
  const city = readFirst(row, ["delivery_city", "city"], "Yangon");
  const cod = Number(readFirst(row, ["cod_amount", "cod", "actual_collect"], 0));
  const deliveryFee = Number(readFirst(row, ["delivery_fee", "total_deli_fee", "deli_fee"], 0));
  const itemPrice = Number(readFirst(row, ["item_price", "item_value", "price"], 0));

  return {
    id: String(readFirst(row, ["id"], tracking)),
    waybill_no: tracking,
    tracking_no: tracking,
    pickup_id: readFirst(row, ["pickup_id", "pickup_request_id"], ""),
    invoice_no: readFirst(row, ["invoice_no", "invoice_id"], ""),
    merchant_code: readFirst(row, ["merchant_code", "customer_code"], ""),
    merchant_name: readFirst(row, ["merchant_name", "sender_name", "customer_name", "merchant"], ""),
    merchant_phone: readFirst(row, ["merchant_phone", "sender_phone", "contact_phone"], ""),
    sender_name: readFirst(row, ["sender_name", "merchant_name", "customer_name"], ""),
    sender_phone: readFirst(row, ["sender_phone", "merchant_phone", "contact_phone"], ""),
    sender_address: readFirst(row, ["sender_address", "pickup_address", "merchant_address"], ""),
    recipient_name: readFirst(row, ["recipient_name", "receiver_name", "consignee_name"], township || "Recipient"),
    recipient_phone: readFirst(row, ["recipient_phone", "receiver_phone", "contact_no_1", "phone"], ""),
    recipient_phone_2: readFirst(row, ["recipient_phone_2", "contact_no_2", "phone_2"], ""),
    recipient_address: readFirst(row, ["recipient_address", "receiver_address", "address"], ""),
    delivery_address: readFirst(row, ["delivery_address", "recipient_address", "receiver_address", "address"], ""),
    delivery_township: township,
    delivery_city: city,
    item_price: itemPrice,
    delivery_fee: deliveryFee,
    prepaid_amount: Number(readFirst(row, ["prepaid_amount", "prepaid"], 0)),
    cod_amount: cod || Math.max(itemPrice + deliveryFee, 0),
    parcel_count: Number(readFirst(row, ["parcel_count", "quantity", "pcs"], 1)),
    weight_kg: Number(readFirst(row, ["weight_kg", "weight"], 0)),
    remarks: readFirst(row, ["remarks", "remark", "special_instruction"], ""),
    status: readFirst(row, ["status"], "Printed"),
    created_at: readFirst(row, ["created_at", "pickup_date"], ""),
  };
}

function qrPayload(row: WaybillRow) {
  return JSON.stringify({
    waybill_no: row.waybill_no,
    pickup_id: row.pickup_id,
    invoice_no: row.invoice_no,
    merchant: row.merchant_name || row.merchant_code,
    recipient: row.recipient_name,
    phone: [row.recipient_phone, row.recipient_phone_2].filter(Boolean).join(", "),
    township: row.delivery_township,
    address: row.delivery_address || row.recipient_address,
    cod_amount: Number(row.cod_amount || 0),
    delivery_fee: Number(row.delivery_fee || 0),
    item_price: Number(row.item_price || 0),
  });
}

function qrUrl(row: WaybillRow) {
  return `https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=0&data=${encodeURIComponent(qrPayload(row))}`;
}

function fallbackQrUrl(row: WaybillRow) {
  return `https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=0&data=${encodeURIComponent(row.waybill_no)}`;
}

function phones(row: WaybillRow) {
  return [row.recipient_phone, row.recipient_phone_2].filter(Boolean).join(", ");
}

function merchantLine(row: WaybillRow) {
  const parts = [row.merchant_name || row.merchant_code, row.merchant_phone].filter(Boolean);
  return parts.join(" / ");
}

function addressLines(row: WaybillRow) {
  const base = cleanText(row.delivery_address || row.recipient_address || row.delivery_township || "");
  return base.split(/\n+/).filter(Boolean);
}

