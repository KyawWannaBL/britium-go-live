  recipient_phone_2?: string;
  recipient_address?: string;
  delivery_address?: string;
  delivery_township?: string;
  delivery_city?: string;
  item_price?: number;
  delivery_fee?: number;
  prepaid_amount?: number;
  cod_amount?: number;
  parcel_count?: number;
  weight_kg?: number;
  remarks?: string;
  status?: string;
  created_at?: string;
};

