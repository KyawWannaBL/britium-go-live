async function trySelect(table: string, limit = 200) {
  try {
    const { data, error } = await (supabase as any)
      .from(table)
      .select("*")
      .limit(limit);
    if (error) return [];
    return Array.isArray(data) ? data : [];
  } catch {
    return [];
  }
}

export default function WaybillStudioPage() {
  const navigate = useNavigate();
  const [rows, setRows] = useState<WaybillRow[]>(DEMO_ROWS);
  const [paper, setPaper] = useState<PaperSize>("4x6");
  const [search, setSearch] = useState("");
  const [selected, setSelected] = useState<string>("demo-1");
  const [loading, setLoading] = useState(false);
  const [printAllMode, setPrintAllMode] = useState(false);

  const config = sizeConfig(paper);

  const loadRows = useCallback(async () => {
    setLoading(true);
    try {
      const candidates = [
        "be_v_waybill_print_queue",
        "be_waybill_print_queue",
        "parcel_rows",
        "be_data_entry_rows",
        "be_pickup_requests",
      ];

      let loaded: any[] = [];
      for (const table of candidates) {
        loaded = await trySelect(table);
        if (loaded.length) break;
      }

      const normalized = loaded.length ? loaded.map(normalizeWaybill) : DEMO_ROWS;
      setRows(normalized);
      setSelected((old) => normalized.find((r) => r.id === old)?.id || normalized[0]?.id || "");
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    void loadRows();
  }, [loadRows]);

  const filtered = useMemo(() => {
    const q = search.trim().toLowerCase();
    if (!q) return rows;
    return rows.filter((row) =>
      [
        row.waybill_no,
        row.pickup_id,
        row.invoice_no,
        row.merchant_name,
        row.merchant_code,
        row.recipient_name,
        row.recipient_phone,
        row.recipient_phone_2,
        row.delivery_township,
        row.delivery_address,
      ].join(" ").toLowerCase().includes(q)
    );
  }, [rows, search]);

  const selectedRow = filtered.find((row) => row.id === selected) || filtered[0] || DEMO_ROWS[0];

  const printRows = printAllMode ? filtered : [selectedRow];

  const pages = useMemo(() => {
    const grouped: WaybillRow[][] = [];
    for (let i = 0; i < printRows.length; i += config.perPage) {
      grouped.push(printRows.slice(i, i + config.perPage));
    }
    return grouped;
  }, [printRows, config.perPage]);

  function printCurrent() {
    setPrintAllMode(false);
    setTimeout(() => window.print(), 80);
  }

  function printAll() {
    setPrintAllMode(true);
    setTimeout(() => {
      window.print();
      setPrintAllMode(false);
    }, 80);
  }

  function copyQrPayload() {
    navigator.clipboard?.writeText(qrPayload(selectedRow)).catch(() => undefined);
  }

  function downloadCsv() {
    const headers = ["Waybill No", "Merchant", "Recipient", "Phones", "Township", "Address", "Item Price", "Delivery Fee", "Prepaid", "COD"];
    const body = filtered.map((r) => [
      r.waybill_no,
      r.merchant_name,
      r.recipient_name,
      phones(r),
      r.delivery_township,
      r.delivery_address,
      r.item_price,
      r.delivery_fee,
      r.prepaid_amount,
      r.cod_amount,
    ].map((v) => `"${String(v ?? "").replaceAll('"', '""')}"`).join(","));

    const blob = new Blob(["\ufeff" + [headers.join(","), ...body].join("\n")], { type: "text/csv;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "waybill_studio_rows.csv";
    a.click();
    URL.revokeObjectURL(url);
  }

  return (
    <main className="be-ws-page">
      <style>{`
        @media print {
          @page { size: ${config.page}; margin: 0; }
          html, body, #root { margin: 0 !important; padding: 0 !important; background: #fff !important; }
          .be-ws-screen { display: none !important; }
          .be-ws-print { display: block !important; }
          .be-print-page {
            width: ${paper === "A4" ? "210mm" : paper === "A5" ? "148mm" : config.labelW};
            height: ${paper === "A4" ? "297mm" : paper === "A5" ? "210mm" : config.labelH};
            display: flex;
            flex-wrap: wrap;
            align-content: flex-start;
            page-break-after: always;
            break-after: page;
            background: #fff;
          }
          .be-print-page .be-sticker {
            width: ${config.labelW} !important;
            height: ${config.labelH} !important;
            margin: 0 !important;
            box-shadow: none !important;
            border-radius: 0 !important;
          }
          * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
      `}</style>

      <section className="be-ws-screen">
        <header className="be-ws-header">
          <div>
            <p>PRINT & DOCUMENT STUDIO</p>
            <h1>Exact Waybill Studio</h1>
            <span>Sticker format · dynamic data · QR contains waybill number and all visible waybill information</span>
          </div>
          <div className="be-ws-actions">
            <button onClick={() => navigate(-1)}><ArrowLeft size={16} /> Back</button>
            <button onClick={loadRows}>{loading ? <Loader2 className="spin" size={16} /> : <RefreshCw size={16} />} Refresh</button>
            <button onClick={downloadCsv}><Download size={16} /> Export</button>
            <button className="gold" onClick={printCurrent}><Printer size={16} /> Print Selected</button>
            <button className="gold" onClick={printAll}><Printer size={16} /> Print All</button>
          </div>
        </header>

        <section className="be-ws-workbench">
          <aside className="be-ws-left">
            <div className="be-search">
              <Search size={16} />
              <input value={search} onChange={(event) => setSearch(event.target.value)} placeholder="Search waybill, recipient, phone..." />
            </div>

            <div className="be-paper-size">
              {SIZE_OPTIONS.map((item) => (
                <button key={item.key} className={paper === item.key ? "active" : ""} onClick={() => setPaper(item.key)}>
                  <b>{item.label}</b>
                  <span>{item.desc}</span>
                </button>
              ))}
            </div>

            <div className="be-row-list">
              {filtered.map((row) => (
                <button key={row.id} onClick={() => setSelected(row.id)} className={selectedRow.id === row.id ? "active" : ""}>
                  <FileText size={15} />
                  <span>
                    <b>{row.waybill_no}</b>
                    <small>{row.recipient_name || row.delivery_township} · {phones(row) || "No phone"}</small>
                  </span>
                </button>
              ))}
              {!filtered.length && <p className="empty">No waybills found.</p>}
            </div>
          </aside>

          <section className="be-ws-preview">
            <div className="be-preview-top">
              <div>
                <h2>Live Preview</h2>
                <p>Selected size: {paper}. QR data updates per waybill row.</p>
              </div>
              <button onClick={copyQrPayload}><QrCode size={15} /> Copy QR Data</button>
            </div>

            <div className={`be-preview-canvas be-preview-${config.previewClass}`}>
              <WaybillSticker row={selectedRow} paper={paper} />
            </div>

            <div className="be-data-box">
              <h3>QR Payload for {selectedRow.waybill_no}</h3>
              <pre>{qrPayload(selectedRow)}</pre>
            </div>
          </section>
        </section>
      </section>

      <section className="be-ws-print" aria-hidden="true">
        {pages.map((page, pageIndex) => (
          <div className="be-print-page" key={pageIndex}>
            {page.map((row) => (
              <WaybillSticker key={row.id} row={row} paper={paper} />
            ))}
          </div>
        ))}
      </section>
    </main>
  );
}
