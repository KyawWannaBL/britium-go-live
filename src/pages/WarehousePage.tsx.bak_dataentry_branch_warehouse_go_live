import { useEffect, useMemo, useState } from 'react';
import {
  AlertTriangle,
  Box,
  CheckCircle2,
  Clock,
  Loader2,
  PackageCheck,
  RefreshCw,
  Search,
  Truck,
  Warehouse,
  XCircle,
} from 'lucide-react';

import { supabase } from '@/integrations/supabase/client';
