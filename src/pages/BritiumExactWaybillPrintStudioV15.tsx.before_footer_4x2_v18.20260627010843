  const selectedRows = rows.filter((row) => selected[normalized(row).waybill]);

  function toggle(row: WaybillRow) {
    const id = normalized(row).waybill;
    setSelected((current) => ({ ...current, [id]: !current[id] }));
    setActiveWaybill(id);
  }

  function selectAllVisible() {
    const next = { ...selected };
    filtered.forEach((row) => {
      next[normalized(row).waybill] = true;
    });
    setSelected(next);
  }

  function clearAll() {
    setSelected({});
  }

