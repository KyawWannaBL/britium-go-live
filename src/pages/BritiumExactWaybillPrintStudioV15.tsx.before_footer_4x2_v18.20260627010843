        .be-title{font-weight:900;font-size:11.5pt;letter-spacing:.1px;white-space:nowrap;}
        .be-subtitle{font-weight:900;font-size:10.5pt;margin-top:1.5mm;white-space:nowrap;}
        .be-hotline-label{font-weight:700;font-size:8.5pt;margin-top:2.5mm;}
        .be-qr-block{width:25mm;text-align:center;margin-left:1mm;flex:0 0 auto;}
