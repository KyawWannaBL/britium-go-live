  const [loading, setLoading] = useState(false);

  async function refresh() {
    setLoading(true);
    try {
      const data = await loadRows();
      setRows(data);
      setActiveWaybill((current) => current || normalized(data[0] || ({} as WaybillRow)).waybill);
      const first: Record<string, boolean> = {};
      if (data[0]) first[normalized(data[0]).waybill] = true;
      setSelected((current) => (Object.keys(current).length ? current : first));
