    const html = rowsToPrint
      .map((row) => {
        const r = normalized(row);
        return `
          <div class="print-page">
            <div class="be-print-wrap">
              ${document.querySelector(`[data-waybill-preview="${CSS.escape(r.waybill)}"]`)?.innerHTML || ""}
            </div>
          </div>`;
      })
      .join("");

    const style = document.getElementById("be-waybill-v17-styles")?.innerHTML || "";
    const win = window.open("", "_blank", "width=900,height=700");
    if (!win) return;

    win.document.write(`
      <html>
        <head>
          <title>Britium Waybill Print</title>
          <style>${style}</style>
          <style>
            body{margin:0;background:white;}
            .print-page{page-break-after:always;display:flex;justify-content:center;align-items:flex-start;padding:0;}
            .be-print-wrap{margin:0;}
            @page{size:auto;margin:0;}
          </style>
        </head>
        <body>${html}</body>
      </html>
    `);
    win.document.close();
    setTimeout(() => {
      win.focus();
      win.print();
    }, 250);
  }

  return (
    <main className="min-h-screen bg-[#061525] p-4 text-slate-100 md:p-6">
      <style id="be-waybill-v17-styles">{`
