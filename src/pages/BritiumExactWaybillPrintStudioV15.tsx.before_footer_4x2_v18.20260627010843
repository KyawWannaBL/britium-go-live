type SizeKey = "4x6" | "4x3" | "2x3" | "A5" | "A4";

type WaybillRow = {
  waybill_no: string;
  pickup_id?: string;
  invoice_no?: string;
  merchant?: string;
  merchant_name?: string;
  merchant_code?: string;
  recipient?: string;
  recipient_name?: string;
  customer_name?: string;
  consignee_name?: string;
  phone?: string;
  contact_no?: string;
  recipient_phone?: string;
  customer_phone?: string;
  township?: string;
  township_mm?: string;
  destination_township?: string;
  address?: string;
  recipient_address?: string;
  delivery_address?: string;
  customer_address?: string;
  consignee_address?: string;
  remark?: string;
  remarks?: string;
  item_price?: any;
  delivery_fee?: any;
  delivery_fees?: any;
  total_delivery_fee?: any;
  prepaid_amount?: any;
  cod?: any;
  actual_collect?: any;
  qr_payload?: string;
};

const SIZE_PRESETS: Record<SizeKey, { label: string; width: string; height: string; note: string }> = {
  "4x6": { label: "4 x 6", width: "104mm", height: "156mm", note: "Main sticker" },
  "4x3": { label: "4 x 3", width: "104mm", height: "78mm", note: "Half sticker" },
  "2x3": { label: "2 x 3", width: "52mm", height: "78mm", note: "Small sticker" },
  A5: { label: "A5", width: "148mm", height: "210mm", note: "2 labels / page" },
  A4: { label: "A4", width: "210mm", height: "297mm", note: "4 labels / page" },
};

function n(value: any) {
  const parsed = Number(String(value ?? "").replace(/[^\d.-]/g, ""));
  return Number.isFinite(parsed) ? parsed : 0;
}

function money(value: any) {
  return n(value).toLocaleString("en-US");
}

function text(...values: any[]) {
  for (const value of values) {
    const s = String(value ?? "").trim();
    if (
      s &&
      s !== "-" &&
      s.toLowerCase() !== "null" &&
      s.toLowerCase() !== "undefined" &&
      s.toLowerCase() !== "multiline text"
    ) {
      return s;
    }
  }
  return "";
}

function makeQrUrl(payload: string) {
  return `https://api.qrserver.com/v1/create-qr-code/?size=180x180&margin=0&data=${encodeURIComponent(payload)}`;
}

function normalized(row: WaybillRow) {
  const waybill = text(row.waybill_no, row.invoice_no, "YGN119874YGN");
  const merchant = text(row.merchant, row.merchant_name, row.merchant_code);
  const recipient = text(row.recipient, row.recipient_name, row.customer_name, row.consignee_name);
  const phone = text(row.phone, row.contact_no, row.recipient_phone, row.customer_phone);
  const township = text(row.township, row.township_mm, row.destination_township);
  const address = text(row.address, row.recipient_address, row.delivery_address, row.customer_address, row.consignee_address);
  const remarks = text(row.remarks, row.remark);
  const itemPrice = n(row.item_price);
  const deliveryFee = n(row.total_delivery_fee, row.delivery_fee, row.delivery_fees);
  const prepaid = n(row.prepaid_amount);
  const cod = n(row.cod, row.actual_collect) || Math.max(0, itemPrice + deliveryFee - prepaid);

  const qrPayload =
    row.qr_payload ||
    JSON.stringify({
      waybill_no: waybill,
      pickup_id: row.pickup_id || "",
      merchant,
      recipient,
      phone,
      township,
      address,
      amount: cod,
    });

  return {
    waybill,
    merchant,
    recipient,
    phone,
    township,
    address,
    remarks,
    itemPrice,
    deliveryFee,
    prepaid,
    cod,
    qrPayload,
  };
}

