function mapRow(row: any, index: number): WaybillRow {
  return {
    waybill_no:
      text(row.waybill_no, row.delivery_way_id, row.delivery_way_no, row.invoice_no, row.parcel_no) ||
      `YGN${String(index + 1).padStart(6, "0")}YGN`,
    pickup_id: row.pickup_id,
    invoice_no: row.invoice_no,
    merchant: text(row.merchant, row.merchant_name, row.merchant_code, row.sender_name),
    merchant_name: row.merchant_name,
    merchant_code: row.merchant_code,
    recipient: text(row.recipient, row.recipient_name, row.customer_name, row.consignee_name, row.receiver_name),
    recipient_name: row.recipient_name,
    customer_name: row.customer_name,
    consignee_name: row.consignee_name,
    phone: text(row.phone, row.contact_no, row.recipient_phone, row.customer_phone, row.receiver_phone),
    contact_no: row.contact_no,
    recipient_phone: row.recipient_phone,
    customer_phone: row.customer_phone,
    township: text(row.township, row.township_mm, row.destination_township, row.receiver_township),
    township_mm: row.township_mm,
    destination_township: row.destination_township,
    address: text(row.address, row.recipient_address, row.delivery_address, row.customer_address, row.consignee_address, row.receiver_address),
    recipient_address: row.recipient_address,
    delivery_address: row.delivery_address,
    customer_address: row.customer_address,
    consignee_address: row.consignee_address,
    remark: row.remark,
    remarks: row.remarks,
    item_price: row.item_price,
    delivery_fee: row.delivery_fee,
    delivery_fees: row.delivery_fees,
    total_delivery_fee: row.total_delivery_fee,
    prepaid_amount: row.prepaid_amount,
    cod: row.cod,
    actual_collect: row.actual_collect,
    qr_payload: row.qr_payload,
  };
}

async function loadRows(): Promise<WaybillRow[]> {
  const rpcNames = [
    "be_data_entry_load_registration_lines_v5",
    "be_data_entry_waybill_print_rows",
    "be_waybill_print_rows",
  ];

  for (const rpc of rpcNames) {
    try {
      const { data, error } = await (supabase as any).rpc(rpc, {});
      const rows = Array.isArray(data) ? data : Array.isArray(data?.rows) ? data.rows : [];
      if (!error && rows.length) return rows.map(mapRow);
    } catch {}
  }

  const tables = [
    "be_data_entry_registration_lines",
    "be_portal_waybills",
    "be_waybills",
    "be_portal_pickup_requests",
  ];

  for (const table of tables) {
    try {
      const { data, error } = await supabase.from(table).select("*").limit(500);
      if (!error && Array.isArray(data) && data.length) {
        return data.map(mapRow);
      }
    } catch {}
  }

  return [
    {
      waybill_no: "YGN119874YGN",
      merchant: "",
      recipient: "N Okkalapa",
      phone: "09792970776, 09792970776",
      township: "မြောက်ဥက္ကလာပ",
      address: "လိပ်စာအချက်အလက် မရရှိသေးပါ",
      remarks: "",
      item_price: 0,
      delivery_fee: 0,
      prepaid_amount: 0,
      cod: 0,
    },
  ];
}

export default function BritiumExactWaybillPrintStudioV15() {
