        .be-head-left{display:flex;gap:2.5mm;align-items:flex-start;min-width:0;}
        .be-logo{width:17.5mm;height:17.5mm;border-radius:50%;display:flex;align-items:center;justify-content:center;flex:0 0 auto;overflow:hidden;}
