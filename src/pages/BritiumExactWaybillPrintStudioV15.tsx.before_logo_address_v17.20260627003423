import React, { useEffect, useMemo, useState } from "react";
import QRCode from "qrcode";
import { ArrowLeft, CheckSquare, Printer, RefreshCw, Search, Square } from "lucide-react";
import { supabase } from "@/integrations/supabase/client";

type SizeKey = "4x6" | "4x3" | "2x3" | "A5" | "A4";
type WaybillRow = Record<string, any>;

const SIZE_PRESETS: Record<SizeKey, { label: string; width: string; height: string; note: string }> = {
  "4x6": { label: "4 x 6", width: "104mm", height: "156mm", note: "Main sticker" },
  "4x3": { label: "4 x 3", width: "104mm", height: "78mm", note: "Half sticker" },
  "2x3": { label: "2 x 3", width: "52mm", height: "78mm", note: "Small sticker" },
  A5: { label: "A5", width: "148mm", height: "210mm", note: "2 labels / page" },
  A4: { label: "A4", width: "210mm", height: "297mm", note: "4 labels / page" },
};

function num(value: any) {
  const parsed = Number(String(value ?? "").replace(/[^\d.-]/g, ""));
  return Number.isFinite(parsed) ? parsed : 0;
}

function money(value: any) {
  return num(value).toLocaleString("en-US");
}

function firstText(...values: any[]) {
  for (const value of values) {
    const s = String(value ?? "").trim();
    if (s && s !== "-" && s.toLowerCase() !== "null" && s.toLowerCase() !== "undefined") return s;
  }
  return "";
}

function normalize(row: WaybillRow) {
  const waybill = firstText(row.waybill_no, row.delivery_way_id, row.invoice_no, row.way_id, "YGN119874YGN");
  const itemPrice = num(row.item_price);
  const deliveryFee = num(row.total_delivery_fee || row.delivery_fee || row.delivery_fees || row.deli_fee);
  const prepaid = num(row.prepaid_amount || row.prepaid);
  const cod = num(row.cod || row.actual_collect) || Math.max(0, itemPrice + deliveryFee - prepaid);
  return {
    waybill,
    merchant: firstText(row.merchant, row.merchant_name, row.merchant_code),
    recipient: firstText(row.recipient, row.recipient_name, row.customer_name, row.consignee, "Recipient"),
    phone: firstText(row.phone, row.contact_no, row.recipient_phone, row.mobile),
    township: firstText(row.township, row.destination_township),
    address: firstText(row.address, row.recipient_address, row.delivery_address, "Multiline Text"),
    remarks: firstText(row.remarks, row.remark, row.note),
    itemPrice,
    deliveryFee,
    prepaid,
    cod,
    qrPayload: row.qr_payload || JSON.stringify({ waybill_no: waybill, phone: firstText(row.phone, row.contact_no), cod }),
  };
}

function Logo() {
  return <div className="be-logo"><div className="be-logo-inner">B</div></div>;
}

