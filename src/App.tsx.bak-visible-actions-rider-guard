              {group.title}
            </div>

            <div className="space-y-1">
              {group.links.map((link) => {
                const Icon = link.icon;

                const isActive =
                  location.pathname === link.path ||
                  location.pathname.startsWith(`${link.path}/`);

                return (
                  <Link
                    key={link.path}
                    to={link.path}
                    className={`flex items-center gap-3 p-3 rounded-xl transition-all duration-200 text-[13px] font-semibold tracking-wide ${
                      isActive
                        ? "bg-[#1a3a5c] text-[#f6b84b] shadow-md"
                        : "text-[#c8dff0] hover:bg-[#0f243b] hover:text-white"
                    }`}
                  >
                    <Icon size={16} strokeWidth={isActive ? 2.5 : 2} />
                    <span>{link.name}</span>
                  </Link>
                );
              })}
            </div>
          </div>
        ))}
      </div>

      <div className="p-4 border-t border-[#1a3a5c] shrink-0 bg-[#0a1628]">
        <button
          type="button"
          onClick={handleSignOut}
          className="w-full flex items-center gap-3 p-3 text-[#ff4f86] font-bold text-[13px] tracking-wide hover:bg-[#ff4f86]/10 rounded-xl transition-colors cursor-pointer"
