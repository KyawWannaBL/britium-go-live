    await supabase.auth.signOut();
    navigate("/", { replace: true });
  }

  return (
    <aside
      className={`w-64 bg-[#0a1628] border-r border-[#1a3a5c] flex flex-col h-screen shrink-0 ${GLOBAL_FONT}`}
    >
