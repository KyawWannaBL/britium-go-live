const FULL_CLASS = "be-data-entry-hard-fullscreen-v28";
const EXIT_ID = "be-data-entry-hard-fullscreen-exit-v28";
const STYLE_ID = "be-data-entry-hard-fullscreen-style-v28";
const RECOVER_FLAG = "be_data_entry_fullscreen_recovered_v28";

function isDataEntryRoute() {
  const route = `${window.location.hash || ""} ${window.location.pathname || ""}`.toLowerCase();
  return route.includes("data-entry");
}

function buttonInfo(target: EventTarget | null) {
  const el = (target as HTMLElement | null)?.closest?.("button, a, [role='button']") as HTMLElement | null;
  return { el, text: String(el?.innerText || el?.textContent || "").trim().toLowerCase() };
}

function hasOldStrippedScreen() {
  const bodyText = String(document.body?.innerText || "");
  return (
    bodyText.includes("DATA ENTRY REGISTRATION FULL SCREEN") &&
    bodyText.includes("Rider proof pending") &&
    !bodyText.includes("Bulk Upload Excel") &&
    !bodyText.includes("Download Template")
  );
}

function injectStyle() {
  if (document.getElementById(STYLE_ID)) return;
  const style = document.createElement("style");
  style.id = STYLE_ID;
  style.textContent = `
    html.${FULL_CLASS}, html.${FULL_CLASS} body {
      margin: 0 !important;
      overflow: hidden !important;
      background: #061525 !important;
    }
    html.${FULL_CLASS} #root {
      position: fixed !important;
      inset: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      overflow: auto !important;
      background: #061525 !important;
      z-index: 2147483000 !important;
    }
    html.${FULL_CLASS} main,
    html.${FULL_CLASS} [data-be-data-entry-stable-root="true"] {
      min-height: 100vh !important;
      width: 100% !important;
    }
    #${EXIT_ID} {
      position: fixed !important;
      top: 14px !important;
      right: 18px !important;
      z-index: 2147483647 !important;
      border: 0 !important;
      border-radius: 14px !important;
      padding: 12px 18px !important;
      background: #ffbd3f !important;
      color: #061524 !important;
      font-size: 14px !important;
      font-weight: 900 !important;
      box-shadow: 0 16px 40px rgba(0,0,0,.35) !important;
      cursor: pointer !important;
    }
  `;
  document.head.appendChild(style);
}

async function exitFullscreen() {
  document.getElementById(EXIT_ID)?.remove();
  document.documentElement.classList.remove(FULL_CLASS);
  document.body.classList.remove(FULL_CLASS);
  document.body.style.overflow = "";
  document.documentElement.style.overflow = "";
  try {
    if (document.fullscreenElement && document.exitFullscreen) await document.exitFullscreen();
  } catch {}
  if (hasOldStrippedScreen()) {
    window.location.hash = "#/data-entry";
    window.setTimeout(() => window.location.reload(), 50);
  }
}

function ensureExitButton() {
  if (document.getElementById(EXIT_ID)) return;
  const button = document.createElement("button");
  button.id = EXIT_ID;
  button.type = "button";
  button.textContent = "Exit Full Screen";
  button.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();
    void exitFullscreen();
  });
  document.body.appendChild(button);
}

async function enterFullscreen() {
  injectStyle();
  sessionStorage.removeItem(RECOVER_FLAG);
  document.documentElement.classList.add(FULL_CLASS);
  document.body.classList.add(FULL_CLASS);
  document.body.style.overflow = "hidden";
  document.documentElement.style.overflow = "hidden";
  ensureExitButton();
  try {
    if (document.documentElement.requestFullscreen && !document.fullscreenElement) await document.documentElement.requestFullscreen();
  } catch {}
  try {
    window.scrollTo({ top: 0, left: 0, behavior: "instant" as ScrollBehavior });
  } catch {}
}

function recoverIfStripped() {
  if (!isDataEntryRoute()) return;
  if (!hasOldStrippedScreen()) return;
  injectStyle();
  ensureExitButton();
  if (!sessionStorage.getItem(RECOVER_FLAG)) {
    sessionStorage.setItem(RECOVER_FLAG, "1");
    window.location.hash = "#/data-entry";
    window.setTimeout(() => window.location.reload(), 100);
  }
}

document.addEventListener(
  "click",
  (event) => {
    if (!isDataEntryRoute()) return;
    const { el, text } = buttonInfo(event.target);
    if (!el || !text) return;

    const wantsEnter = text.includes("full screen data entry") || text.includes("fullscreen data entry");
    const wantsExit = text.includes("exit full screen") || text.includes("exit fullscreen");

    if (!wantsEnter && !wantsExit) return;

    event.preventDefault();
    event.stopPropagation();
    (event as any).stopImmediatePropagation?.();

    if (wantsExit) void exitFullscreen();
    else void enterFullscreen();
  },
  true,
);

document.addEventListener("fullscreenchange", () => {
  if (!document.fullscreenElement && document.documentElement.classList.contains(FULL_CLASS)) void exitFullscreen();
});

document.addEventListener("keydown", (event) => {
  if (event.key === "Escape" && document.documentElement.classList.contains(FULL_CLASS)) {
    event.preventDefault();
    void exitFullscreen();
  }
});

const observer = new MutationObserver(() => recoverIfStripped());
observer.observe(document.documentElement, { childList: true, subtree: true });

window.setTimeout(recoverIfStripped, 500);
window.setTimeout(recoverIfStripped, 1500);
window.setTimeout(recoverIfStripped, 3000);

export {};
