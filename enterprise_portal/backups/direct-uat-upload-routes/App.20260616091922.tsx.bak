  { path: "/go-live-readiness", title: "Go-Live Readiness", group: "Admin", candidates: ["UATGoLiveCommandCenterPage", "GoLiveReadinessCenterPage", "GoLiveRouteHealthPage", "GoLiveDataControlPanel"] }
