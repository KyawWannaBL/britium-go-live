type RouteDef = {
  path: string;
  title: string;
  group: "Operations" | "Portals" | "Finance" | "Data" | "Data Entry" | "Field Team" | "Commerce" | "Admin";
  candidates: string[];
  aliases?: string[];
};

const ROUTES: RouteDef[] = [
  { path: "/dashboard", title: "Dashboard", group: "Operations", candidates: ["UATGoLiveCommandCenterPage", "DashboardPage", "Dashboard", "Index"] },
  { path: "/supervisor", title: "Supervisor", group: "Operations", candidates: ["SupervisorPortalPage", "SupervisorPickupAssignmentGoLivePage", "SupervisorPortal", "SupervisorGoLiveScreen"] },
  { path: "/ops-manager", title: "Ops Manager", group: "Operations", candidates: ["OpsManagerPage", "OperationsPage", "OperationManagementPortalPage", "OperationsCommandCenterPage", "ExecutiveOperationsDashboardPage"] },
  { path: "/dispatch", title: "Dispatch", group: "Operations", candidates: ["DispatchPage", "DispatchGoLivePage"] },
  { path: "/delivery-dispatch", title: "Delivery Dispatch", group: "Operations", candidates: ["DeliveryHighDensityHubPage", "DeliveryDispatchPage", "DeliveryDispatchBoard"] },
  { path: "/warehouse", title: "Warehouse", group: "Operations", candidates: ["WarehouseUATUploadPage", "WarehousePage", "WarehousePortalPage", "WarehouseInventoryGoLiveScreen", "WarehouseRegistrationTemplatePage"], aliases: ["/warehouse/scan", "/warehouse/upload", "/warehouse-upload", "/warehouse-scan"] },
  { path: "/branch-office", title: "Branch Office", group: "Operations", candidates: ["BranchOfficePage", "BranchOfficeGoLivePage", "BranchOfficeAdminDashboardPage"] },

