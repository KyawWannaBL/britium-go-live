  { path: "/customer", title: "Customer", group: "Portals", candidates: ["PortalUploadCenterPage", "CustomerPortalPage", "CustomerPage", "CustomerPortalDashboard"], aliases: ["/customer/upload", "/customer-upload"] },
  { path: "/customer-service", title: "Customer Service", group: "Portals", candidates: ["CustomerServiceCommandCenterPage", "CustomerServicePortalPage", "CustomerServicePage", "CustomerServiceGoLiveScreen", "CustomerServiceEnterpriseLivePage"], aliases: ["/cs", "/customer-service/portal"] },

  { path: "/finance", title: "Finance", group: "Finance", candidates: ["FinancePortalPage", "FinancePage", "FinancialCenter", "FinanceGoLiveReportsPage"], aliases: ["/finance/manager", "/finance/accountant", "/finance/cashier", "/finance/auditor"] },
  { path: "/invoice-studio", title: "Invoice Studio", group: "Finance", candidates: ["DocumentPrintStudioPage", "InvoiceStudioPage", "InvoicePrintStudioPage", "InvoicePrintingStudioPage", "WaybillPrintStudioPage"], aliases: ["/document-print-studio", "/print-studio", "/waybill-print-studio", "/waybill-printing-studio", "/invoice-print-studio"] },
  { path: "/workforce-commission", title: "Workforce Commission", group: "Finance", candidates: ["WorkforceCommissionPage", "WorkforcePage"] },
