const TESTING_ENV = (import.meta.env.VITE_APP_ENV || import.meta.env.MODE || "testing").toString();

function routeCandidatesToKeys(candidates: string[]) {
  return candidates.map((name) => `./pages/${name}.tsx`);
}

function getBestPageLoader(candidates: string[]) {
  const key = routeCandidatesToKeys(candidates).find((candidate) => Object.prototype.hasOwnProperty.call(pageModules, candidate));
  if (!key) return null;
  return pageModules[key];
}

function lazyPage(candidates: string[], title: string) {
  const loader = getBestPageLoader(candidates);
  if (!loader) {
    return function MissingConfiguredPage() {
      return <MissingPage title={title} candidates={candidates} />;
    };
  }

  return lazy(async () => {
    try {
      const mod = await loader();
      if (mod.default) return { default: mod.default };
      const named = Object.values(mod).find((value) => typeof value === "function" || (typeof value === "object" && value !== null));
      if (named) return { default: named as PageComponent };
      return { default: () => <MissingPage title={title} candidates={candidates} reason="No default export was found." /> };
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error);
      return { default: () => <MissingPage title={title} candidates={candidates} reason={message} /> };
    }
  });
}

function getActiveRoute(pathname: string): RouteDef {
  const route = ROUTES.find((item) => item.path === pathname || item.aliases?.includes(pathname));
  return route || ROUTES[0];
}

function getRouteElements() {
  const elements: React.ReactNode[] = [];
  for (const route of ROUTES) {
    const allPaths = [route.path, ...(route.aliases || [])];
    const Page = lazyPage(route.candidates, route.title);
    for (const path of allPaths) {
      elements.push(
        <Route
          key={path}
          path={path.replace(/^\//, "")}
          element={
            <PortalShell title={route.title}>
              <RouteBoundary title={route.title}>
                <Suspense fallback={<PageLoading title={route.title} />}>
                  <Page />
                </Suspense>
              </RouteBoundary>
            </PortalShell>
          }
        />
      );
    }
  }
  return elements;
}

function PageLoading({ title }: { title: string }) {
  return (
    <div className="be-loading-card">
      <div className="be-loading-spinner" />
      <div>
        <strong>Loading {title}</strong>
        <span>Preparing testing workspace…</span>
      </div>
    </div>
  );
}

function MissingPage({ title, candidates, reason }: { title: string; candidates: string[]; reason?: string }) {
  return (
    <div className="be-empty-state">
      <div className="be-empty-icon">⚠</div>
      <div>
        <p className="be-kicker">SCREEN NOT WIRED</p>
        <h2>{title} page module is not available</h2>
        <p>
          App.tsx has the route wired for testing, but none of these page modules were found:
        </p>
        <code>{candidates.join(", ")}</code>
        {reason ? <p className="be-error-note">{reason}</p> : null}
      </div>
    </div>
  );
}

class RouteBoundary extends Component<{ children: ReactNode; title: string }, { error: Error | null }> {
  state = { error: null as Error | null };

  static getDerivedStateFromError(error: Error) {
    return { error };
  }

  componentDidCatch(error: Error, info: ErrorInfo) {
    console.error(`[BritiumRouteBoundary:${this.props.title}]`, error, info);
  }

  render() {
    if (!this.state.error) return this.props.children;

    return (
      <div className="be-empty-state be-empty-state-danger">
        <div className="be-empty-icon">!</div>
        <div>
          <p className="be-kicker">PAGE ERROR</p>
          <h2>{this.props.title} could not render</h2>
          <p>{this.state.error.message}</p>
          <button className="be-btn be-btn-primary" type="button" onClick={() => this.setState({ error: null })}>
            Retry page
          </button>
        </div>
      </div>
    );
  }
}

function TestingLogin() {
  return (
    <div className="be-login-screen">
      <div className="be-login-card">
        <div className="be-brand-mark">BE</div>
        <p className="be-kicker">TESTING ENVIRONMENT</p>
        <h1>Britium Enterprise Portal</h1>
        <p>Testing shell is active. Use Supabase testing credentials on your real LoginPage if it exists.</p>
        <Link className="be-btn be-btn-primary" to="/dashboard">
          Enter testing dashboard
        </Link>
      </div>
    </div>
  );
}

function LoginRoute() {
  const Login = useMemo(() => lazyPage(["LoginPage", "Login", "BritiumPremiumLoginPage"], "Login"), []);
  const hasLogin = Boolean(getBestPageLoader(["LoginPage", "Login", "BritiumPremiumLoginPage"]));

  if (!hasLogin) return <TestingLogin />;

  return (
    <Suspense fallback={<PageLoading title="Login" />}>
      <Login />
    </Suspense>
  );
}

function PortalShell({ children, title }: { children: ReactNode; title: string }) {
  const [collapsed, setCollapsed] = useState(false);
  const [query, setQuery] = useState("");
  const location = useLocation();
  const activeRoute = getActiveRoute(location.pathname);

  const visibleGroups = useMemo(() => {
    const normalized = query.trim().toLowerCase();
    const groups = groupRoutes(ROUTES);
    if (!normalized) return groups;

    return groups
      .map((group) => ({
        ...group,
        items: group.items.filter((item) => `${item.title} ${item.path}`.toLowerCase().includes(normalized))
      }))
      .filter((group) => group.items.length > 0);
  }, [query]);

  return (
    <div className={collapsed ? "be-app be-app-collapsed" : "be-app"}>
      <aside className="be-sidebar" aria-label="Britium navigation">
        <div className="be-sidebar-brand">
          <div className="be-logo-dot">◉</div>
          {!collapsed ? (
            <div>
              <strong>Britium Express</strong>
              <span>Enterprise Portal</span>
            </div>
          ) : null}
        </div>

        <nav className="be-nav">
          {visibleGroups.map((group) => (
            <section className="be-nav-group" key={group.label}>
              {!collapsed ? <p>{group.label}</p> : null}
              {group.items.map((item) => (
                <Link
                  key={item.path}
                  className={item.path === activeRoute.path || item.aliases?.includes(location.pathname) ? "be-nav-link is-active" : "be-nav-link"}
                  to={item.path}
                  title={item.title}
                >
                  <span className="be-nav-icon">{getIcon(item.group)}</span>
                  {!collapsed ? <span>{item.title}</span> : null}
                </Link>
              ))}
            </section>
          ))}
        </nav>

        <div className="be-sidebar-footer">
          <button className="be-sidebar-action" type="button" onClick={() => setCollapsed((value) => !value)}>
            <span>{collapsed ? "›" : "‹"}</span>
            {!collapsed ? "Collapse" : null}
          </button>
          <Link className="be-sidebar-action" to="/login">
            <span>↩</span>
            {!collapsed ? "Sign out" : null}
          </Link>
        </div>
      </aside>

      <main className="be-main">
        <header className="be-topbar">
          <div>
            <h1>{title}</h1>
            <span>{TESTING_ENV === "production" ? "Production" : "Testing"} workspace</span>
          </div>

          <div className="be-topbar-tools">
            <label className="be-search">
              <span>⌕</span>
              <input
                value={query}
                onChange={(event) => setQuery(event.target.value)}
                placeholder="Search modules, waybill, merchant..."
                aria-label="Search modules"
              />
            </label>
            <span className="be-role-chip">Super Admin</span>
            <span className="be-env-chip">{TESTING_ENV}</span>
          </div>
        </header>

        <section className="be-page-shell">
          <div className="be-page-host">{children}</div>
        </section>
      </main>
    </div>
  );
}

function groupRoutes(routes: RouteDef[]) {
  const order: RouteDef["group"][] = ["Operations", "Portals", "Finance", "Data", "Data Entry", "Field Team", "Commerce", "Admin"];
  return order
    .map((label) => ({
      label,
      items: routes.filter((route) => route.group === label)
    }))
    .filter((group) => group.items.length > 0);
}

function getIcon(group: RouteDef["group"]) {
  switch (group) {
    case "Operations":
      return "▦";
    case "Portals":
      return "◎";
    case "Finance":
      return "$";
    case "Data":
      return "▤";
    case "Data Entry":
      return "✎";
    case "Field Team":
      return "♢";
    case "Commerce":
      return "↗";
    case "Admin":
      return "⚙";
    default:
      return "•";
  }
}


