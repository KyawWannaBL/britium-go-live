      "waybill_no",
      "merchant_code",
      "merchant_name",
      "expected_parcel_count",
      "scanned_parcel_count",
      "remaining_count",
      "tracking_no",
      "scan_type",
      "current_status",
      "next_status",
      "bag_code",
      "bag_destination",
      "route_zone",
      "exception_reason",
      "damage_note",
      "missing_parcel_note",
      "validation_status",
      "api_message"
    ]
  }
};

function downloadUatCsv(template: UatTemplateDef) {
  const sample = template.columns.map((column) => {
    if (column === "row_no") return "1";
    if (column.includes("date")) return new Date().toISOString().slice(0, 10);
    if (column.includes("time")) return new Date().toTimeString().slice(0, 5);
    if (column === "requester_type") return template.key === "customer" ? "customer" : "merchant";
    if (column === "payment_method") return "COD";
    if (column === "service_type") return "Standard";
    if (column.includes("parcel_count")) return "1";
    if (column === "weight_kg") return "1";
    if (column.includes("amount") || column.includes("fee") || column === "item_value") return "0";
    return "";
  });

  const csv = [
    template.columns.join(","),
    sample.map((value) => `"${String(value).replace(/"/g, '""')}"`).join(",")
  ].join("\n");

  const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");

  a.href = url;
  a.download = template.file;
  document.body.appendChild(a);
  a.click();
  a.remove();

  URL.revokeObjectURL(url);
}

function DirectTemplateCenter() {
  return (
    <div style={uatStyles.wrap}>
      <h1 style={uatStyles.title}>Template Center</h1>
      <p style={uatStyles.lead}>
        Download backend-aligned CSV templates for UAT upload validation.
      </p>

      <div style={uatStyles.grid}>
        {Object.values(UAT_TEMPLATES).map((template) => (
          <section key={template.key} style={uatStyles.card}>
            <h2 style={uatStyles.cardTitle}>{template.title}</h2>
            <p style={uatStyles.text}>{template.description}</p>
            <p style={uatStyles.badge}>{template.columns.length} columns</p>

            <button
              type="button"
              style={uatStyles.primaryButton}
              onClick={() => downloadUatCsv(template)}
            >
              Download CSV
            </button>
          </section>
        ))}
      </div>
    </div>
  );
}

function DirectUploadPage({ template }: { template: UatTemplateDef }) {
  const [fileName, setFileName] = useState("");
  const [rows, setRows] = useState(0);

  const onUpload = async (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];

    if (!file) {
      setFileName("");
      setRows(0);
      return;
    }

    setFileName(file.name);

    const text = await file.text();
    const lines = text.split(/\r?\n/).filter((line) => line.trim());
    setRows(Math.max(lines.length - 1, 0));
  };

  return (
    <div style={uatStyles.wrap}>
      <h1 style={uatStyles.title}>{template.title}</h1>
      <p style={uatStyles.lead}>{template.description}</p>

      <section style={uatStyles.card}>
        <button
          type="button"
          style={uatStyles.primaryButton}
          onClick={() => downloadUatCsv(template)}
        >
          Download CSV Format
        </button>

        <label style={uatStyles.label}>
          Upload CSV
          <input
            type="file"
            accept=".csv,text/csv"
            onChange={onUpload}
            style={uatStyles.input}
          />
        </label>

        <div style={uatStyles.result}>
          <strong>Selected file:</strong> {fileName || "No file selected"}
          <br />
          <strong>Detected rows:</strong> {rows}
          <br />
          <strong>Status:</strong> Ready for backend validation/import.
        </div>

        <h2 style={uatStyles.sectionTitle}>Required Columns</h2>
        <div style={uatStyles.columnGrid}>
          {template.columns.map((column) => (
            <span key={column} style={uatStyles.columnPill}>
              {column}
            </span>
          ))}
        </div>
      </section>
    </div>
  );
}

function DirectWarehouseScan() {
  const [scan, setScan] = useState("");
  const [lastScan, setLastScan] = useState("");

  return (
    <div style={uatStyles.wrap}>
      <h1 style={uatStyles.title}>Warehouse Scan</h1>
      <p style={uatStyles.lead}>
        Scan or enter Pickup ID, Deliver ID, Invoice No, Waybill No, QR value, or Bag Code.
      </p>

      <section style={uatStyles.card}>
        <label style={uatStyles.label}>
          Scan Value
          <input
            value={scan}
            onChange={(event) => setScan(event.target.value)}
            placeholder="Example: W0525-BBK-015"
            style={uatStyles.input}
            autoFocus
          />
        </label>

        <button
          type="button"
          style={uatStyles.primaryButton}
          onClick={() => {
            setLastScan(scan.trim());
            setScan("");
          }}
        >
          Confirm Scan
        </button>

        <div style={uatStyles.result}>
          <strong>Last scan:</strong> {lastScan || "None"}
          <br />
          <strong>Backend action:</strong> Warehouse scan record + cargo event + exception validation.
        </div>
      </section>
    </div>
  );
}

