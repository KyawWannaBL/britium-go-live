function AppRoutes() {
  return (
    <Routes>
      <Route path="/login" element={<LoginRoute />} />
      <Route path="/" element={<Navigate to="/dashboard" replace />} />

      <Route
        path="templates"
        element={
          <PortalShell title="Templates">
            <DirectTemplateCenter />
          </PortalShell>
        }
      />
      <Route
        path="data-entry-upload"
        element={
          <PortalShell title="Data Entry Upload">
            <DirectUploadPage template={UAT_TEMPLATES.dataEntry} />
          </PortalShell>
        }
      />
      <Route
        path="merchant-upload"
        element={
          <PortalShell title="Merchant Upload">
            <DirectUploadPage template={UAT_TEMPLATES.merchant} />
          </PortalShell>
        }
      />
      <Route
        path="customer-upload"
        element={
          <PortalShell title="Customer Upload">
            <DirectUploadPage template={UAT_TEMPLATES.customer} />
          </PortalShell>
        }
      />
      <Route
        path="warehouse-upload"
        element={
          <PortalShell title="Warehouse Upload">
            <DirectUploadPage template={UAT_TEMPLATES.warehouse} />
          </PortalShell>
        }
      />
      <Route
        path="warehouse-scan"
        element={
          <PortalShell title="Warehouse Scan">
            <DirectWarehouseScan />
          </PortalShell>
        }
      />

      {getRouteElements()}
      <Route
        path="*"
        element={
          <PortalShell title="Route Not Found">
            <MissingPage title="Route" candidates={["Route is not configured in App.tsx"]} reason={window.location.hash || window.location.pathname} />
          </PortalShell>
        }
      />
    </Routes>
  );
}

export default function App() {
  return (
    <HashRouter>
      <AppRoutes />
    </HashRouter>
  );
}
