// @ts-nocheck
import { FormEvent, useState } from "react";
import { supabase } from "@/integrations/supabase/client";

const VIDEO_URL =
  "https://skyagent-artifacts.skywork.ai/router/agent/2026-06-09/prod_agent_73dcc7b2-6a06-4769-ba6f-a24e8e15113e/background_a93e0a05bfce4d5fa60d226584905742.mp4";

const LOGO_URL =
  "https://skyagent-artifacts.skywork.ai/router/agent/2026-06-09/prod_agent_73dcc7b2-6a06-4769-ba6f-a24e8e15113e/logo_869b883bce9e40f59d6394b5f754ef08.png";

const YEAR = new Date().getFullYear();

function clearAuthStorage() {
  try {
    Object.keys(localStorage).forEach((key) => {
      const k = key.toLowerCase();
      if (
        key.startsWith("sb-") ||
        key.startsWith("be_") ||
        k.includes("supabase") ||
        k.includes("auth-token")
      ) {
        localStorage.removeItem(key);
      }
    });

    Object.keys(sessionStorage).forEach((key) => {
      const k = key.toLowerCase();
      if (
        key.startsWith("sb-") ||
        key.startsWith("be_") ||
        k.includes("supabase") ||
        k.includes("auth-token")
      ) {
        sessionStorage.removeItem(key);
      }
    });
  } catch {}
}

function timeoutPromise<T>(promise: Promise<T>, ms: number, label: string): Promise<T> {
  return Promise.race([
    promise,
    new Promise<T>((_, reject) => {
      setTimeout(() => reject(new Error(`${label} timed out after ${ms / 1000}s`)), ms);
    }),
  ]);
}

function getSupabaseConfig() {
  const url =
    import.meta.env.VITE_SUPABASE_URL ||
    (supabase as any).supabaseUrl ||
    "";

  const key =
    import.meta.env.VITE_SUPABASE_ANON_KEY ||
    (supabase as any).supabaseKey ||
    "";

  if (!url || !key) {
    throw new Error("Supabase URL or anon key is missing from frontend environment.");
  }

  return {
    url: String(url).replace(/\/$/, ""),
    key: String(key),
  };
}

function storeSupabaseSession(url: string, authJson: any) {
  try {
    const projectRef = new URL(url).hostname.split(".")[0];

    const expiresAt =
      authJson.expires_at ||
      Math.floor(Date.now() / 1000) + Number(authJson.expires_in || 3600);

    const sessionPayload = {
      access_token: authJson.access_token,
      refresh_token: authJson.refresh_token,
      expires_in: authJson.expires_in || 3600,
      expires_at: expiresAt,
      token_type: authJson.token_type || "bearer",
      user: authJson.user,
    };

    localStorage.setItem(`sb-${projectRef}-auth-token`, JSON.stringify(sessionPayload));
  } catch (err) {
    console.warn("Could not manually store Supabase session", err);
  }
}

async function restPasswordLogin(email: string, password: string) {
  const { url, key } = getSupabaseConfig();

  console.log("ENTERPRISE_FINAL_AUTH_START", email);

  const authResponse = await timeoutPromise(
    fetch(`${url}/auth/v1/token?grant_type=password`, {
      method: "POST",
      headers: {
        apikey: key,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        email,
        password,
      }),
    }),
    15000,
    "Supabase password login"
  );

  const authJson = await authResponse.json().catch(() => ({}));

  if (!authResponse.ok) {
    console.error("ENTERPRISE_FINAL_AUTH_FAILED", authResponse.status, authJson);
    throw new Error(
      authJson?.error_description ||
        authJson?.msg ||
        authJson?.message ||
        `Supabase authentication failed with status ${authResponse.status}`
    );
  }

  if (!authJson?.access_token) {
    console.error("ENTERPRISE_FINAL_NO_TOKEN", authJson);
    throw new Error("Supabase login returned no access token.");
  }

  console.log("ENTERPRISE_FINAL_AUTH_OK");

  storeSupabaseSession(url, authJson);

  console.log("ENTERPRISE_FINAL_ACCESS_START");

  const accessResponse = await timeoutPromise(
    fetch(`${url}/rest/v1/rpc/be_resolve_user_access_by_email`, {
      method: "POST",
      headers: {
        apikey: key,
        Authorization: `Bearer ${authJson.access_token}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        p_email: email,
      }),
    }),
    15000,
    "Backend access resolver"
  );

  const accessJson = await accessResponse.json().catch(() => ({}));

  if (!accessResponse.ok) {
    console.error("ENTERPRISE_FINAL_ACCESS_FAILED", accessResponse.status, accessJson);
    throw new Error(
      accessJson?.message ||
        accessJson?.hint ||
        accessJson?.details ||
        `Backend access resolver failed with status ${accessResponse.status}`
    );
  }

  if (!accessJson?.ok) {
    console.error("ENTERPRISE_FINAL_ACCESS_DENIED", accessJson);
    throw new Error(accessJson?.error || "Backend access profile not found for this email.");
  }

  console.log("ENTERPRISE_FINAL_ACCESS_OK", accessJson);

  return {
    auth: authJson,
    access: accessJson,
  };
}

export default function LoginPage() {
  console.log("enterprise-login-final-rest-only-20260614");

  const [lang, setLang] = useState<"en" | "my">("en");
  const [email, setEmail] = useState(localStorage.getItem("be_login_email") || "sai@britiumexpress.com");
  const [password, setPassword] = useState("");
  const [showPw, setShowPw] = useState(false);
  const [busy, setBusy] = useState(false);
  const [message, setMessage] = useState("");
  const [error, setError] = useState("");

  const t =
    lang === "en"
      ? {
          tagline: "Enterprise Management Portal",
          portal: "ENTERPRISE PORTAL",
          signIn: "Sign In",
          email: "EMAIL ADDRESS",
          password: "PASSWORD",
          button: "Sign In to Portal",
          processing: "Authenticating...",
          backend:
            "No frontend role selected. Role, portal, branch, and permissions are assigned by backend email access profile.",
          footer: "Authorised personnel only",
          forgot: "Forgot password?",
        }
      : {
          tagline: "စီမံခန့်ခွဲမှု Enterprise Portal",
          portal: "ENTERPRISE PORTAL",
          signIn: "ဝင်ရောက်",
          email: "အီးမေးလ်",
          password: "စကားဝှက်",
          button: "Portal ဝင်ရောက်",
          processing: "အတည်ပြုနေသည်...",
          backend:
            "Frontend role မရွေးပါ။ Role, portal, branch နှင့် permissions ကို backend email profile မှ သတ်မှတ်သည်။",
          footer: "ခွင့်ပြုထားသောဝန်ထမ်းများသာ",
          forgot: "စကားဝှက်မေ့သွားသလား?",
        };

  async function handleSubmit(e: FormEvent) {
    e.preventDefault();

    if (busy) return;

    const normalizedEmail = String(email || "").trim().toLowerCase();
    const normalizedPassword = String(password || "").trim();

    setError("");
    setMessage("");

    if (!normalizedEmail) {
      setError("Email is required.");
      return;
    }

    if (!normalizedPassword) {
      setError("Password is required.");
      return;
    }

    setBusy(true);
    setMessage("Authenticating...");

    try {
      clearAuthStorage();

      const result = await restPasswordLogin(normalizedEmail, normalizedPassword);
      const access = result.access;

      localStorage.setItem("be_user_authenticated", "true");
      localStorage.setItem("be_login_email", normalizedEmail);
      localStorage.setItem("be_user_email", normalizedEmail);
      localStorage.setItem("be_user_role", access.role || "");
      localStorage.setItem("be_user_portal", access.portal || "");
      localStorage.setItem("be_branch_code", access.branch_code || "HQ");
      localStorage.setItem("be_user_access_profile", JSON.stringify(access));
      localStorage.setItem("be_session_ok", "true");

      setMessage("Access granted. Redirecting...");

      setTimeout(() => {
        window.location.replace("/#/dashboard");
      }, 300);
    } catch (err: any) {
      console.error("ENTERPRISE_FINAL_LOGIN_FAILED", err);
      setError(err?.message || "Login failed.");
      setMessage("");
      setBusy(false);
    }
  }

  const inputStyle: any = {
    width: "100%",
    padding: "13px 14px",
    border: "1.5px solid #e4e4e7",
    borderRadius: 10,
    background: "#fafafa",
    color: "#18181b",
    fontSize: 14,
    fontWeight: 600,
    outline: "none",
  };

  return (
    <div
      style={{
        position: "relative",
        minHeight: "100vh",
        width: "100%",
        overflow: "hidden",
        fontFamily: "Poppins, Inter, system-ui, sans-serif",
      }}
    >
      <video
        style={{
          position: "absolute",
          inset: 0,
          width: "100%",
          height: "100%",
          objectFit: "cover",
        }}
        src={VIDEO_URL}
        autoPlay
        muted
        loop
        playsInline
      />

      <div
        style={{
          position: "absolute",
          inset: 0,
          background:
            "linear-gradient(140deg, rgba(4,14,28,0.86), rgba(8,22,45,0.72), rgba(6,12,24,0.86))",
        }}
      />

      <button
        type="button"
        onClick={() => setLang((old) => (old === "en" ? "my" : "en"))}
        style={{
          position: "absolute",
          top: 18,
          right: 18,
          zIndex: 30,
          padding: "8px 14px",
          borderRadius: 10,
          border: "1px solid rgba(255,255,255,.2)",
          background: "rgba(255,255,255,.1)",
          color: "#fff",
          cursor: "pointer",
        }}
      >
        🌐 {lang === "en" ? "မြန်မာ" : "EN"}
      </button>

      <div
        style={{
          position: "relative",
          zIndex: 10,
          minHeight: "100vh",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          padding: 20,
        }}
      >
        <div style={{ width: "100%", maxWidth: 430 }}>
          <div style={{ textAlign: "center", marginBottom: 26 }}>
            <div
              style={{
                width: 64,
                height: 64,
                borderRadius: 16,
                overflow: "hidden",
                background: "#fff",
                margin: "0 auto 14px",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                boxShadow: "0 6px 30px rgba(0,0,0,.35)",
              }}
            >
              <img
                src={LOGO_URL}
                alt="Britium Express"
                style={{ width: "100%", height: "100%", objectFit: "contain" }}
              />
            </div>

            <h1
              style={{
                fontSize: 22,
                fontWeight: 900,
                color: "#fff",
                letterSpacing: ".08em",
                margin: 0,
              }}
            >
              BRITIUM EXPRESS
            </h1>

            <p
              style={{
                fontSize: 10,
                fontWeight: 900,
                color: "#f59e0b",
                letterSpacing: ".18em",
                marginTop: 6,
                textTransform: "uppercase",
              }}
            >
              {t.tagline}
            </p>
          </div>

          <div
            style={{
              background: "#fff",
              borderRadius: 20,
              boxShadow: "0 24px 70px rgba(0,0,0,.5)",
              overflow: "hidden",
            }}
          >
            <div style={{ padding: 26 }}>
              <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 18 }}>
                <div>
                  <div
                    style={{
                      fontSize: 10,
                      color: "#f59e0b",
                      fontWeight: 900,
                      letterSpacing: ".16em",
                    }}
                  >
                    {t.portal}
                  </div>

                  <h2 style={{ margin: "5px 0 0", color: "#18181b", fontSize: 24, fontWeight: 900 }}>
                    {t.signIn}
                  </h2>
                </div>

                <div style={{ color: "#71717a", fontWeight: 900, fontSize: 12 }}>v2026</div>
              </div>

              {error ? (
                <div
                  style={{
                    marginBottom: 14,
                    padding: 12,
                    borderRadius: 10,
                    color: "#b91c1c",
                    background: "#fee2e2",
                    fontWeight: 700,
                    fontSize: 13,
                  }}
                >
                  {error}
                </div>
              ) : null}

              {message ? (
                <div
                  style={{
                    marginBottom: 14,
                    padding: 12,
                    borderRadius: 10,
                    color: "#166534",
                    background: "#dcfce7",
                    fontWeight: 700,
                    fontSize: 13,
                  }}
                >
                  {message}
                </div>
              ) : null}

              <form onSubmit={handleSubmit} style={{ display: "grid", gap: 15 }}>
                <div>
                  <label
                    style={{
                      display: "block",
                      color: "#71717a",
                      fontWeight: 900,
                      fontSize: 11,
                      marginBottom: 6,
                    }}
                  >
                    {t.email}
                  </label>

                  <input
                    value={email}
                    onChange={(e) => setEmail(e.target.value)}
                    style={inputStyle}
                    type="email"
                    autoComplete="username"
                  />
                </div>

                <div>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                    <label
                      style={{
                        display: "block",
                        color: "#71717a",
                        fontWeight: 900,
                        fontSize: 11,
                        marginBottom: 6,
                      }}
                    >
                      {t.password}
                    </label>

                    <button
                      type="button"
                      onClick={() => alert("Password reset is disabled in UAT. Ask admin to reset from Supabase Auth.")}
                      style={{
                        border: 0,
                        background: "transparent",
                        color: "#2563eb",
                        fontWeight: 700,
                        fontSize: 12,
                        cursor: "pointer",
                      }}
                    >
                      {t.forgot}
                    </button>
                  </div>

                  <div style={{ position: "relative" }}>
                    <input
                      value={password}
                      onChange={(e) => setPassword(e.target.value)}
                      style={inputStyle}
                      type={showPw ? "text" : "password"}
                      autoComplete="current-password"
                    />

                    <button
                      type="button"
                      onClick={() => setShowPw((old) => !old)}
                      style={{
                        position: "absolute",
                        right: 10,
                        top: "50%",
                        transform: "translateY(-50%)",
                        border: 0,
                        background: "transparent",
                        cursor: "pointer",
                      }}
                    >
                      {showPw ? "🙈" : "👁"}
                    </button>
                  </div>
                </div>

                <button
                  type="submit"
                  style={{
                    width: "100%",
                    padding: "14px 0",
                    borderRadius: 12,
                    border: "none",
                    background: busy ? "#fbbf24" : "#f59e0b",
                    color: "#1c1917",
