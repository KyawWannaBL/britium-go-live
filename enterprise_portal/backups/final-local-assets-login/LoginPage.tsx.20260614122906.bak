              color: "rgba(255,255,255,.75)",
              textAlign: "center",
              fontSize: 11,
            }}
          >
            {t.footer}
          </div>

          <p
            style={{
              textAlign: "center",
              marginTop: 10,
              fontSize: 10,
              color: "rgba(255,255,255,.45)",
            }}
          >
            © {YEAR} Britium Express · Britium Ventures Co., Ltd · All rights reserved
          </p>
        </div>
      </div>
    </div>
  );
}
