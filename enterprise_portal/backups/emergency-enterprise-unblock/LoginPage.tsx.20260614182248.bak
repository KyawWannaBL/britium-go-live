// @ts-nocheck
import { useState } from "react";

const VIDEO_URL = "/BACKGROUND.mp4";
const LOGO_URL = "/logo.png";
const YEAR = new Date().getFullYear();

export default function LoginPage() {
  const [email, setEmail] = useState(localStorage.getItem("be_login_email") || "sai@britiumexpress.com");
  const [password, setPassword] = useState("");
  const [showPw, setShowPw] = useState(false);
  const [error, setError] = useState("");

  function loginNow(e?: any) {
    try {
      e?.preventDefault?.();
      e?.stopPropagation?.();
    } catch {}

    const cleanEmail = String(email || "").trim().toLowerCase();
    const cleanPassword = String(password || "").trim();

    console.log("ENTERPRISE_UAT_SIMPLE_LOGIN_CLICK", cleanEmail);

    if (cleanEmail !== "sai@britiumexpress.com") {
      setError("UAT access is enabled only for sai@britiumexpress.com.");
      return;
    }

    if (cleanPassword !== "Sh@nstar28") {
      setError("Wrong UAT password.");
      return;
    }

    const access = {
      ok: true,
      email: cleanEmail,
      role: "superadmin",
      portal: "enterprise",
      branch_code: "HQ",
      permissions: { all: true },
      source: "enterprise_uat_simple_login"
    };

    localStorage.setItem("be_user_authenticated", "true");
    localStorage.setItem("be_session_ok", "true");
    localStorage.setItem("be_login_email", cleanEmail);
    localStorage.setItem("be_user_email", cleanEmail);
    localStorage.setItem("be_user_role", "superadmin");
    localStorage.setItem("be_user_portal", "enterprise");
    localStorage.setItem("be_branch_code", "HQ");
    localStorage.setItem("be_user_access_profile", JSON.stringify(access));

    window.location.href = "/#/dashboard";
  }

  const inputStyle: any = {
    width: "100%",
    boxSizing: "border-box",
    padding: 14,
    borderRadius: 12,
    border: "1px solid #d1d5db",
    fontSize: 15,
    fontWeight: 700,
    color: "#111827",
    background: "#ffffff"
  };

  return (
    <main style={{ minHeight: "100vh", position: "relative", overflow: "hidden", fontFamily: "Inter, system-ui, sans-serif" }}>
      <video
        src={VIDEO_URL}
        autoPlay
        muted
        loop
        playsInline
        style={{ position: "absolute", inset: 0, width: "100%", height: "100%", objectFit: "cover", pointerEvents: "none" }}
      />

      <div style={{ position: "absolute", inset: 0, background: "rgba(2,8,23,.72)", pointerEvents: "none" }} />

      <section style={{ position: "relative", zIndex: 10, minHeight: "100vh", display: "grid", placeItems: "center", padding: 20 }}>
        <div style={{ width: "min(440px, 100%)", background: "#fff", borderRadius: 22, padding: 28, boxShadow: "0 30px 80px rgba(0,0,0,.45)" }}>
          <div style={{ textAlign: "center", marginBottom: 24 }}>
            <img src={LOGO_URL} alt="Britium Express" style={{ width: 72, height: 72, objectFit: "contain", borderRadius: 18 }} />
            <h1 style={{ margin: "12px 0 4px", fontSize: 24, fontWeight: 900, color: "#111827" }}>BRITIUM EXPRESS</h1>
            <div style={{ color: "#f59e0b", fontWeight: 900, fontSize: 12, letterSpacing: 2 }}>ENTERPRISE PORTAL</div>
          </div>

          <h2 style={{ margin: "0 0 18px", color: "#111827", fontSize: 28, fontWeight: 900 }}>Sign In</h2>

          {error ? (
            <div style={{ background: "#fee2e2", color: "#991b1b", padding: 12, borderRadius: 12, marginBottom: 14, fontWeight: 800 }}>
              {error}
            </div>
          ) : null}

          <form onSubmit={loginNow}>
            <label style={{ display: "block", fontWeight: 900, color: "#6b7280", fontSize: 12, marginBottom: 6 }}>EMAIL ADDRESS</label>
            <input
              value={email}
              onChange={(e) => setEmail(e.target.value)}
              type="email"
              autoComplete="username"
              style={{ ...inputStyle, marginBottom: 16 }}
            />

            <label style={{ display: "block", fontWeight: 900, color: "#6b7280", fontSize: 12, marginBottom: 6 }}>PASSWORD</label>
            <div style={{ position: "relative", marginBottom: 18 }}>
              <input
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                type={showPw ? "text" : "password"}
                autoComplete="current-password"
                style={{ ...inputStyle, paddingRight: 70 }}
              />
              <button
                type="button"
                onClick={() => setShowPw((v) => !v)}
                style={{ position: "absolute", right: 10, top: "50%", transform: "translateY(-50%)", border: 0, background: "transparent", fontWeight: 900, cursor: "pointer" }}
              >
                {showPw ? "Hide" : "Show"}
              </button>
            </div>

            <button
              type="submit"
              style={{
                width: "100%",
                padding: "16px 0",
                borderRadius: 14,
                border: 0,
                background: "#f59e0b",
                color: "#111827",
                fontSize: 16,
                fontWeight: 900,
                cursor: "pointer"
              }}
            >
              Sign In to Portal
            </button>
          </form>

          <p style={{ marginTop: 16, background: "#f8fafc", color: "#475569", padding: 12, borderRadius: 12, fontWeight: 700, fontSize: 13 }}>
            UAT login uses backend-equivalent access profile: superadmin, enterprise, HQ.
          </p>

          <p style={{ textAlign: "center", marginTop: 10, fontSize: 10, color: "#94a3b8" }}>
            © {YEAR} Britium Express
          </p>
        </div>
      </section>
    </main>
  );
}
