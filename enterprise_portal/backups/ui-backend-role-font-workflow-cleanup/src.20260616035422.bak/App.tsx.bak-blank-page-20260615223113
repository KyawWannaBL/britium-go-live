import React from "react";
import { HashRouter, Navigate, NavLink, Route, Routes } from "react-router-dom";

import UATGoLiveCommandCenterPage from "./pages/UATGoLiveCommandCenterPage";
import GoLiveTemplateCenterPage from "./pages/GoLiveTemplateCenterPage";
import DataEntryUATUploadPage from "./pages/DataEntryUATUploadPage";
import PortalUploadCenterPage from "./pages/PortalUploadCenterPage";
import WarehouseUATUploadPage from "./pages/WarehouseUATUploadPage";

const navItems = [
  ["/go-live-readiness", "Go-Live Readiness"],
  ["/templates", "Template Center"],
  ["/data-entry/upload", "Data Entry Upload"],
  ["/merchant/upload", "Merchant Upload"],
  ["/customer/upload", "Customer Upload"],
  ["/warehouse/upload", "Warehouse Upload"],
  ["/warehouse/scan", "Warehouse Scan"],
];

function Shell({ children }: { children: React.ReactNode }) {
  return (
    <div style={styles.app}>
      <aside style={styles.sidebar}>
        <h2 style={styles.brand}>Britium UAT</h2>
        <p style={styles.small}>Login bypassed for UAT smoke testing.</p>

        {navItems.map(([to, label]) => (
          <NavLink
            key={to}
            to={to}
            style={({ isActive }) => ({
              ...styles.link,
              background: isActive
                ? "rgba(255,255,255,0.22)"
                : "rgba(255,255,255,0.08)",
            })}
          >
            {label}
          </NavLink>
        ))}
      </aside>

      <main style={styles.main}>{children}</main>
    </div>
  );
}

export default function App() {
  return (
    <HashRouter>
      <Routes>
        <Route path="/" element={<Navigate to="/go-live-readiness" replace />} />
        <Route path="/login" element={<Navigate to="/go-live-readiness" replace />} />
        <Route path="/dashboard" element={<Navigate to="/go-live-readiness" replace />} />

        <Route
          path="/go-live-readiness"
          element={
            <Shell>
              <UATGoLiveCommandCenterPage />
            </Shell>
          }
        />

        <Route
          path="/templates"
          element={
            <Shell>
              <GoLiveTemplateCenterPage />
            </Shell>
          }
        />

        <Route
          path="/data-entry"
          element={
            <Shell>
              <DataEntryUATUploadPage />
            </Shell>
          }
        />

        <Route
          path="/data-entry/upload"
          element={
            <Shell>
              <DataEntryUATUploadPage />
            </Shell>
          }
        />

        <Route
          path="/merchant/upload"
          element={
            <Shell>
              <PortalUploadCenterPage />
            </Shell>
          }
        />

        <Route
          path="/customer/upload"
          element={
            <Shell>
              <PortalUploadCenterPage />
            </Shell>
          }
        />

        <Route
          path="/warehouse"
          element={
            <Shell>
              <WarehouseUATUploadPage />
            </Shell>
          }
        />

        <Route
          path="/warehouse/upload"
          element={
            <Shell>
              <WarehouseUATUploadPage />
            </Shell>
          }
        />

        <Route
          path="/warehouse/scan"
          element={
            <Shell>
              <WarehouseUATUploadPage />
            </Shell>
          }
        />

        <Route path="*" element={<Navigate to="/go-live-readiness" replace />} />
      </Routes>
    </HashRouter>
  );
}

const styles: Record<string, React.CSSProperties> = {
  app: {
    minHeight: "100vh",
    display: "grid",
    gridTemplateColumns: "260px 1fr",
    background: "#f8fafc",
    color: "#0f172a",
    fontFamily: "Arial, sans-serif",
  },
  sidebar: {
    background: "#0f172a",
    color: "white",
    padding: 20,
  },
  brand: {
    margin: "0 0 8px",
  },
  small: {
    fontSize: 12,
    color: "#cbd5e1",
    marginBottom: 20,
  },
  link: {
    display: "block",
    color: "white",
    textDecoration: "none",
    padding: "12px 14px",
    borderRadius: 10,
    marginBottom: 8,
    fontWeight: 700,
  },
  main: {
    padding: 24,
    overflow: "auto",
  },
};
