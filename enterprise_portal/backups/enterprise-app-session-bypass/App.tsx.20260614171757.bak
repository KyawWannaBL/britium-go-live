import AppLoginPage from "./pages/LoginPage";
type AccessProfile = {
  ok?: boolean;
  email?: string;
  display_name?: string;
  role?: string;
  portal?: string;
  branch_code?: string;
  redirect_path?: string;
  permissions?: any;
};

const navItems = [
  { label: "Dashboard", icon: "📊", path: "/dashboard", code: "dashboard" },
  { label: "Create Delivery", icon: "📦", path: "/create-delivery", code: "create_delivery" },
  { label: "Customer Service Portal", icon: "🎧", path: "/cs-portal", code: "customer_service" },
  { label: "Way Management", icon: "🗺️", path: "/way-management", code: "way_management" },
  { label: "Supervisor Hub", icon: "🧑‍💼", path: "/supervisor", code: "supervisor" },
  { label: "Pickup Assignment", icon: "✅", path: "/supervisor/assignment", code: "pickup_assignment" },
  { label: "Data Entry", icon: "📁", path: "/data-entry", code: "data_entry" },
  { label: "Warehouse Ops", icon: "🏭", path: "/warehouse", code: "warehouse" },
  { label: "Dispatch Center", icon: "🚚", path: "/dispatch", code: "dispatch" },
  { label: "Branch Office", icon: "🏢", path: "/branch-office", code: "branch_office" },
  { label: "Finance Portal", icon: "💰", path: "/finance", code: "finance" },
  { label: "COD Settlement", icon: "💵", path: "/cod-settlement", code: "cod_settlement" },
  { label: "Waybill & Invoice", icon: "🏷️", path: "/waybill-invoice", code: "waybill_invoice" },
  { label: "Merchant Portal", icon: "🏪", path: "/merchant-portal", code: "merchant" },
  { label: "Customer Portal", icon: "👤", path: "/customer-portal", code: "customer" },
  { label: "Marketing", icon: "📣", path: "/marketing", code: "marketing" },
  { label: "Business Development", icon: "🤝", path: "/business-development", code: "business_development" },
  { label: "Operations Manager", icon: "🧭", path: "/ops-manager", code: "ops_manager" },
  { label: "Rider / Driver / Helper Ops", icon: "🏍️", path: "/rider-ops", code: "rider_ops" },
  { label: "Master Data", icon: "🗂️", path: "/master-data", code: "master_data" },
  { label: "Exceptions", icon: "⚠️", path: "/exceptions", code: "exceptions" },
  { label: "Reporting", icon: "📈", path: "/reporting", code: "reporting" },
  { label: "Accounts / HR", icon: "👥", path: "/accounts", code: "accounts" },
  { label: "Tariff", icon: "🧾", path: "/tariff", code: "tariff" },
  { label: "Settings", icon: "⚙️", path: "/settings", code: "settings" },
  { label: "Profile", icon: "🙋", path: "/profile", code: "profile" }
];

const roleRoute: Record<string, string> = {
  superadmin: "/dashboard",
  admin: "/dashboard",
  customer_service: "/cs-portal",
  cs: "/cs-portal",
  supervisor: "/supervisor",
  dispatch: "/dispatch",
  dispatcher: "/dispatch",
  wayplan: "/way-management",
  warehouse: "/warehouse",
  warehouse_staff: "/warehouse",
  data_entry: "/data-entry",
  finance: "/finance",
  accounting: "/finance",
  cashier: "/finance",
  branch_office_manager: "/branch-office",
  branch_manager: "/branch-office",
  branch_admin: "/branch-office",
  marketing: "/marketing",
  business_development_manager: "/business-development",
  bdm: "/business-development",
  merchant: "/merchant-portal",
  customer: "/customer-portal",
  rider: "/rider-ops",
  driver: "/rider-ops",
  helper: "/rider-ops"
};

function saveProfile(profile: AccessProfile) {
  localStorage.setItem("be_user_authenticated", "YES");
  localStorage.setItem("be_user_access_profile", JSON.stringify(profile || {}));
  localStorage.setItem("be_user_email", profile.email || "");
  localStorage.setItem("be_user_role", profile.role || "");
  localStorage.setItem("be_user_portal", profile.portal || "");
  localStorage.setItem("be_branch_code", profile.branch_code || "");
}

function readProfile(): AccessProfile | null {
  try {
    return JSON.parse(localStorage.getItem("be_user_access_profile") || "null");
  } catch {
    return null;
  }
}

async function resolveAccess(email: string): Promise<AccessProfile> {
  const { data, error } = await supabase.rpc("be_resolve_user_access_by_email", {
    p_email: email.toLowerCase().trim()
  });

  if (error) throw error;

  const profile = data as AccessProfile;

  if (!profile || profile.ok === false) {
    throw new Error("This user is authenticated but not mapped in be_user_account_registry.");
  }

  saveProfile(profile);
  return profile;
}

function LegacyInlineLoginPage() {
  const navigate = useNavigate();
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [busy, setBusy] = useState(false);
  const [error, setError] = useState("");

  async function submit(event: FormEvent) {
    event.preventDefault();
    setBusy(true);
    setError("");

    try {
      const cleanEmail = email.toLowerCase().trim();

      const auth = await supabase.auth.signInWithPassword({
        email: cleanEmail,
        password
      });

      if (auth.error) throw auth.error;

      const profile = await resolveAccess(cleanEmail);
      navigate(profile.redirect_path || roleRoute[(profile.role || "").toLowerCase()] || "/dashboard", { replace: true });
    } catch (err: any) {
      await supabase.auth.signOut();
      localStorage.removeItem("be_user_authenticated");
      localStorage.removeItem("be_user_access_profile");
      setError(err?.message || "Login failed");
    } finally {
      setBusy(false);
    }
  }

  return (
    <main className="be-login">
      <form className="be-login-card" onSubmit={submit}>
        <div className="be-logo">BE</div>
        <p className="be-eyebrow">Backend Role Login</p>
        <h1>Britium Enterprise Portal</h1>
        <p className="be-muted">
          Sign in with email and password. The backend assigns role, portal, branch, and access.
        </p>

        {error && <div className="be-alert">{error}</div>}

        <label>Email</label>
        <input value={email} onChange={e => setEmail(e.target.value)} placeholder="you@britiumexpress.com" autoComplete="email" />

        <label>Password</label>
        <input value={password} onChange={e => setPassword(e.target.value)} placeholder="Password" type="password" autoComplete="current-password" />

        <button disabled={busy} type="submit">
          {busy ? "Signing in..." : "Sign in"}
        </button>
      </form>
    </main>
  );
}

function Shell() {
  const navigate = useNavigate();
  const [loading, setLoading] = useState(true);
  const [profile, setProfile] = useState<AccessProfile | null>(readProfile());
  const [error, setError] = useState("");

  useEffect(() => {
    let alive = true;

    async function init() {
      const session = await supabase.auth.getSession();
      const userEmail = session.data.session?.user?.email || "";

      if (!userEmail) {
        if (alive) setLoading(false);
        return;
      }

      try {
        const resolved = await resolveAccess(userEmail);
        if (alive) {
          setProfile(resolved);
          setError("");
        }
      } catch (err: any) {
        if (alive) setError(err?.message || "Access profile failed to load");
      } finally {
        if (alive) setLoading(false);
      }
    }

    init();

    return () => {
      alive = false;
    };
  }, []);

  const filteredNav = useMemo(() => {
    const role = (profile?.role || "").toLowerCase();

    if (["superadmin", "admin"].includes(role)) return navItems;

    const allowByRole: Record<string, string[]> = {
      customer_service: ["dashboard", "customer_service", "create_delivery", "way_management", "exceptions", "reporting"],
      cs: ["dashboard", "customer_service", "create_delivery", "way_management", "exceptions", "reporting"],
      supervisor: ["dashboard", "supervisor", "pickup_assignment", "rider_ops", "exceptions", "reporting"],
      dispatch: ["dashboard", "dispatch", "way_management", "rider_ops", "exceptions", "reporting"],
      dispatcher: ["dashboard", "dispatch", "way_management", "rider_ops", "exceptions", "reporting"],
      warehouse: ["dashboard", "warehouse", "exceptions", "reporting"],
      warehouse_staff: ["dashboard", "warehouse", "exceptions", "reporting"],
      data_entry: ["dashboard", "data_entry", "waybill_invoice", "exceptions"],
      finance: ["dashboard", "finance", "cod_settlement", "waybill_invoice", "reporting"],
      cashier: ["dashboard", "finance", "cod_settlement"],
      branch_office_manager: ["dashboard", "branch_office", "warehouse", "dispatch", "reporting"],
      branch_manager: ["dashboard", "branch_office", "warehouse", "dispatch", "reporting"],
      marketing: ["dashboard", "marketing", "merchant", "reporting"],
      business_development_manager: ["dashboard", "business_development", "merchant", "reporting"],
      bdm: ["dashboard", "business_development", "merchant", "reporting"],
      merchant: ["merchant"],
      customer: ["customer"],
      rider: ["rider_ops"],
      driver: ["rider_ops"],
      helper: ["rider_ops"]
    };

    const allowed = allowByRole[role];
    if (!allowed) return navItems.filter(item => item.code === "dashboard" || item.code === "profile");

    return navItems.filter(item => allowed.includes(item.code) || item.code === "profile");
  }, [profile]);

  async function signOut() {
    await supabase.auth.signOut();
    localStorage.clear();
    navigate("/login", { replace: true });
  }

  if (loading) {
    return <div className="be-loading">Loading Britium Enterprise Portal...</div>;
  }

  return (
    <div className="be-app">
      <aside className="be-sidebar">
        <div className="be-brand">
          <div className="be-logo">BE</div>
          <div>
            <strong>Britium Express</strong>
            <span>Enterprise Portal</span>
          </div>
        </div>

        <nav>
          {filteredNav.map(item => (
            <NavLink key={item.path} to={item.path} className={({ isActive }) => isActive ? "active" : ""}>
              <span>{item.icon}</span>
              <b>{item.label}</b>
            </NavLink>
          ))}
        </nav>
      </aside>

      <main className="be-main">
        <header className="be-topbar">
          <div>
            <p className="be-eyebrow">Britium Express UAT Portal</p>
            <h1>Enterprise Operations</h1>
          </div>

          <div className="be-user">
            <strong>{profile?.email || localStorage.getItem("be_user_email") || "unknown"}</strong>
            <span>{profile?.role || "unmapped"} · {profile?.portal || "-"} · {profile?.branch_code || "-"}</span>
            <div className="be-user-actions"><LanguageToggle /><button onClick={signOut}>Sign out</button></div>
          </div>
        </header>

        {error && <div className="be-alert">{error}</div>}

        <section className="be-content">
          <ReportDownloadPanel />
          <Routes>
            <Route path="/" element={<AppLoginPage />} />
            <Route path="/login" element={<AppLoginPage />} />
          <Route path="/dashboard" element={<P0 />} />
          <Route path="/create-delivery" element={<P1 />} />
          <Route path="/cs-portal" element={<P2 />} />
          <Route path="/way-management" element={<P3 />} />
          <Route path="/supervisor" element={<P4 />} />
          <Route path="/supervisor/assignment" element={<P5 />} />
          <Route path="/data-entry" element={<P6 />} />
          <Route path="/warehouse" element={<P7 />} />
          <Route path="/dispatch" element={<P8 />} />
          <Route path="/branch-office" element={<P9 />} />
          <Route path="/finance" element={<P10 />} />
          <Route path="/cod-settlement" element={<P11 />} />
          <Route path="/waybill-invoice" element={<P12 />} />
          <Route path="/merchant-portal" element={<P13 />} />
          <Route path="/customer-portal" element={<P14 />} />
          <Route path="/marketing" element={<P15 />} />
          <Route path="/business-development" element={<P16 />} />
          <Route path="/ops-manager" element={<P17 />} />
          <Route path="/rider-ops" element={<P18 />} />
          <Route path="/master-data" element={<P19 />} />
          <Route path="/exceptions" element={<P20 />} />
          <Route path="/reporting" element={<P21 />} />
          <Route path="/accounts" element={<P22 />} />
          <Route path="/tariff" element={<P23 />} />
          <Route path="/settings" element={<P24 />} />
          <Route path="/profile" element={<P25 />} />
            <Route path="/proof-gallery" element={<ProofGalleryPortalPage />} />
          <Route path="*" element={<GenericRolePortalPage title="Screen Not Found" code="not_found" />} />
          </Routes>
        </section>
      </main>
    </div>
  );
}

function Gate() {
  const [ready, setReady] = useState(false);
  const [hasSession, setHasSession] = useState(false);

  useEffect(() => {
    supabase.auth.getSession().then(({ data }) => {
      setHasSession(Boolean(data.session));
      setReady(true);
    });
  }, []);

  if (!ready) { console.warn("Auth readiness pending; rendering routes instead of blocking login."); }

  return (hasSession || localStorage.getItem("be_user_authenticated") === "true") ? <Shell /> : <AppLoginPage />;
}

