          --be-bg: #07111f;
          --be-panel: rgba(15, 29, 51, 0.92);
          --be-card: rgba(18, 34, 58, 0.92);
          --be-border: rgba(255, 255, 255, 0.1);
          --be-gold: #e4b72e;
          --be-text: #f8fafc;
          --be-muted: #94a3b8;
          --be-danger: #ff4d4f;
        }

        * { box-sizing: border-box; }

        body {
          margin: 0;
          background: radial-gradient(circle at top, #10223d 0, #07111f 45%, #040812 100%);
          color: var(--be-text);
          font-family: Inter, Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .be-app {
          min-height: 100vh;
          display: grid;
          grid-template-columns: 300px minmax(0, 1fr);
        }

        .be-sidebar {
          background: rgba(6, 13, 25, 0.96);
          border-right: 1px solid var(--be-border);
          padding: 24px 18px;
          position: sticky;
          top: 0;
          height: 100vh;
          overflow: auto;
        }

        .be-brand {
          display: flex;
          align-items: center;
          gap: 14px;
          margin-bottom: 26px;
        }

        .be-logo {
          width: 54px;
          height: 54px;
          border-radius: 16px;
          background: linear-gradient(135deg, #facc15, #b8870f);
          color: #06111f;
          display: grid;
          place-items: center;
          font-weight: 950;
          box-shadow: 0 14px 34px rgba(228, 183, 46, 0.2);
        }

        .be-brand strong { display: block; font-size: 20px; }
        .be-brand span { color: var(--be-muted); font-size: 13px; }

        nav {
          display: grid;
          gap: 8px;
        }

        nav a {
          display: flex;
          align-items: center;
          gap: 12px;
          padding: 12px 14px;
          border-radius: 14px;
          color: #dbeafe;
          text-decoration: none;
          border: 1px solid transparent;
        }

        nav a.active, nav a:hover {
          background: rgba(228, 183, 46, 0.12);
          border-color: rgba(228, 183, 46, 0.35);
          color: #fff;
        }

        nav a span { width: 24px; text-align: center; }
        nav a b { font-size: 14px; }

        .be-main {
          min-width: 0;
        }

        .be-topbar {
          min-height: 118px;
          padding: 28px 32px;
          display: flex;
          justify-content: space-between;
          align-items: center;
          gap: 20px;
          background: rgba(7, 18, 35, 0.95);
          border-bottom: 1px solid var(--be-border);
        }

        .be-eyebrow {
          color: #facc15;
          letter-spacing: 0.16em;
          text-transform: uppercase;
          font-size: 12px;
          font-weight: 900;
          margin: 0 0 8px;
        }

        h1 { margin: 0; font-size: 30px; }
        h2 { margin: 0 0 16px; }
        h3 { margin: 0 0 8px; }

        .be-user {
          display: grid;
          gap: 4px;
          justify-items: end;
          color: #e2e8f0;
        }


        .be-user-actions {
          display: flex;
          align-items: center;
          justify-content: flex-end;
          gap: 8px;
          margin-top: 8px;
        }

        .be-user-actions button {
          height: 38px;
          min-height: 38px;
          padding: 0 12px;
          min-width: auto;
          border-radius: 12px;
        }

        .be-user span, .be-muted {
          color: var(--be-muted);
        }

        button {
          border: 0;
          border-radius: 12px;
          background: var(--be-gold);
          color: #07111f;
          font-weight: 900;
          padding: 10px 16px;
          cursor: pointer;
        }

        .be-content {
          padding: 28px 32px 60px;
        }

        .be-alert {
          margin: 20px 32px 0;
          padding: 14px 18px;
          border: 1px solid rgba(228, 183, 46, 0.45);
          border-radius: 14px;
          background: rgba(60, 35, 35, 0.55);
          color: #facc15;
        }

        .be-page-header {
          margin-bottom: 24px;
        }

        .be-card-grid {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
          gap: 16px;
          margin-bottom: 24px;
        }

        .be-card, .be-panel {
          background: var(--be-card);
          border: 1px solid var(--be-border);
          border-radius: 18px;
          padding: 20px;
          box-shadow: 0 20px 50px rgba(0,0,0,0.18);
        }

        .be-card p {
          font-size: 24px;
          font-weight: 950;
          margin: 0;
        }

        .be-table-wrap {
          overflow: auto;
        }

        .be-table {
          width: 100%;
          border-collapse: collapse;
          min-width: 720px;
        }

        .be-table th, .be-table td {
          text-align: left;
          padding: 12px;
          border-bottom: 1px solid var(--be-border);
        }

        .be-table th {
          color: #facc15;
          font-size: 12px;
          text-transform: uppercase;
          letter-spacing: 0.08em;
        }

        .be-error {
          color: var(--be-danger);
        }

        .be-login {
          min-height: 100vh;
          display: grid;
          place-items: center;
          padding: 24px;
        }

        .be-login-card {
          width: min(440px, 100%);
          background: rgba(6, 13, 25, 0.96);
          border: 1px solid var(--be-border);
          border-radius: 24px;
          padding: 28px;
          box-shadow: 0 30px 90px rgba(0,0,0,0.45);
          display: grid;
          gap: 14px;
        }

        .be-login-card label {
          font-weight: 800;
          color: #cbd5e1;
          font-size: 13px;
        }

        .be-login-card input {
          width: 100%;
          padding: 13px 14px;
          border-radius: 12px;
          border: 1px solid rgba(255,255,255,0.14);
          background: rgba(15, 29, 51, 0.96);
          color: #fff;
          outline: none;
        }

        .be-loading {
          min-height: 100vh;
          display: grid;
          place-items: center;
          color: #facc15;
          font-weight: 900;
        }

        @media (max-width: 900px) {
          .be-app {
            grid-template-columns: 1fr;
          }

          .be-sidebar {
            position: static;
            height: auto;
          }

          .be-topbar {
